<script>
// Function to setup slider
function setupSlider(sliderId, handleId) {
    const slider = document.getElementById(sliderId);
    const handle = document.getElementById(handleId);
    const afterImg = slider.querySelectorAll('img')[1];
    let isDragging = false;

    handle.addEventListener('mousedown', () => { isDragging = true; });
    document.addEventListener('mouseup', () => { isDragging = false; });
    document.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        const rect = slider.getBoundingClientRect();
        let offsetX = e.clientX - rect.left;
        if (offsetX < 0) offsetX = 0;
        if (offsetX > rect.width) offsetX = rect.width;
        const percent = (offsetX / rect.width) * 100;
        afterImg.style.width = percent + '%';
        handle.style.left = percent + '%';
    });

    // Support touch for mobile
    handle.addEventListener('touchstart', () => { isDragging = true; });
    document.addEventListener('touchend', () => { isDragging = false; });
    document.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const touch = e.touches[0];
        const rect = slider.getBoundingClientRect();
        let offsetX = touch.clientX - rect.left;
        if (offsetX < 0) offsetX = 0;
        if (offsetX > rect.width) offsetX = rect.width;
        const percent = (offsetX / rect.width) * 100;
        afterImg.style.width = percent + '%';
        handle.style.left = percent + '%';
    });
}

// Initialize all 3 sliders
setupSlider('slider1','handle1');
setupSlider('slider2','handle2');
setupSlider('slider3','handle3');
</script>

